        'R': 'Default',
        'S': 'Orthopedics',
        'T': 'Emergency',
        'U': 'Infectious',
        'Z': 'Default',
    };
    return letterMap[letter] || 'Default';
}

// ═══════════════════════════════════════════════════════════════════════════
// SAFE NUMBER HELPER: Ensures we never return NaN, undefined, or negative
// ═══════════════════════════════════════════════════════════════════════════

function safeNumber(value: any, fallback: number): number {
    const num = Number(value);
    if (isNaN(num) || !isFinite(num) || num < 0) {
        return fallback;
    }
    return num;
}

function safePositive(value: any, min: number): number {
    const num = safeNumber(value, min);
    return Math.max(num, min);
}

// ═══════════════════════════════════════════════════════════════════════════
// MAIN LOOKUP FUNCTION (4-Layer Failsafe)
// ═══════════════════════════════════════════════════════════════════════════

export function lookupICD(icdCode: string, diagnosisName?: string): ICDLookupResult {
    const code = (icdCode || '').trim().toUpperCase();
    const name = (diagnosisName || '').trim().toLowerCase();

    // ─── LAYER 1: Cost Database Lookup ───────────────────────────────────────
    let costMatch: any = null;
    if (code) {
        costMatch = costConditions.find((c: any) => c.icd_code?.toUpperCase() === code);
        if (!costMatch) costMatch = costConditions.find((c: any) => c.icd_code?.toUpperCase().startsWith(code));
        if (!costMatch) costMatch = costConditions.find((c: any) => code.startsWith(c.icd_code?.toUpperCase() || ''));
    }
    // Also try name match in cost DB
    if (!costMatch && name) {
        costMatch = costConditions.find((c: any) => c.condition?.toLowerCase().includes(name));
    }

    if (costMatch) {
        return {
            found: true,
            source: 'cost_db',
            icdCode: costMatch.icd_code || code || 'R69',
            conditionName: costMatch.condition || name || 'Medical Condition',
            specialty: costMatch.specialty || 'Default',
            isSurgical: costMatch.is_surgical || false,
            los: {
                min: safeNumber(costMatch.los?.min, 3),
                max: safeNumber(costMatch.los?.max, 10),
                avg: safeNumber(costMatch.los?.avg, 5),
                icu: safeNumber(costMatch.los?.icu, 0),
            },
            costData: {
                ward: safePositive(costMatch.private?.ward, MINIMUM_FLOOR.room_rent),
                semi: safePositive(costMatch.private?.semi, MINIMUM_FLOOR.room_rent * 1.8),
                pvt: safePositive(costMatch.private?.pvt, MINIMUM_FLOOR.room_rent * 3),
                icu: safePositive(costMatch.private?.icu, 20000),
                invest: safePositive(costMatch.private?.invest, MINIMUM_FLOOR.investigations),
                med_per_day: safePositive(costMatch.private?.med_per_day, MINIMUM_FLOOR.medicines),
                consult: safePositive(costMatch.private?.consult, MINIMUM_FLOOR.consult),
                procedure: safeNumber(costMatch.private?.procedure, 0),
                pmjay_eligible: costMatch.pmjay?.eligible || false,
                pmjay_rate: safeNumber(costMatch.pmjay?.rate, 15000),
            },
        };
    }

    // ─── LAYER 1B: Clinical Database Lookup ──────────────────────────────────
    let clinicalMatch: any = null;
    if (code) {
        clinicalMatch = clinicalConditions.find((c: any) => {
            const primaryCode = c.icd_codes?.primary?.code?.toUpperCase();
            return primaryCode === code || primaryCode?.startsWith(code) || code.startsWith(primaryCode || '');
        });
    }
    if (!clinicalMatch && name) {
        clinicalMatch = clinicalConditions.find((c: any) =>
            c.condition_name?.toLowerCase().includes(name) ||
            name.includes(c.condition_name?.toLowerCase() || '') ||
            c.keywords?.some((k: string) => name.includes(k.toLowerCase()))
        );
    }

    if (clinicalMatch) {
        const specialty = clinicalMatch.specialty || getSpecialtyFromICD(clinicalMatch.icd_codes?.primary?.code || code);
        const defaults = SPECIALTY_COSTS[specialty] || SPECIALTY_COSTS['Default'];
        const isSurgical = (clinicalMatch.expected_procedures || []).some((p: string) =>
            /surgery|ectomy|otomy|plasty|scopy|section|repair|fixation|replacement/i.test(p)
        );

        return {
            found: true,
            source: 'clinical_db',
            icdCode: clinicalMatch.icd_codes?.primary?.code || code || 'R69',
            conditionName: clinicalMatch.condition_name || name || 'Medical Condition',
            specialty: specialty,
            isSurgical: isSurgical,
            los: {
                min: safeNumber(clinicalMatch.expected_length_of_stay?.min_days, defaults.los_avg - 2),
                max: safeNumber(clinicalMatch.expected_length_of_stay?.max_days, defaults.los_avg + 4),
                avg: safeNumber(clinicalMatch.expected_length_of_stay?.typical_days, defaults.los_avg),
                icu: safeNumber(clinicalMatch.expected_length_of_stay?.icu_days, defaults.los_icu),
            },
            costData: {
                ...defaults,
                pmjay_eligible: clinicalMatch.pmjay_eligible ?? defaults.pmjay_eligible,
                pmjay_rate: safeNumber(clinicalMatch.pmjay_rate, defaults.pmjay_rate),
            },
        };
    }

    // ─── LAYER 2: Keyword Mapping ────────────────────────────────────────────
    if (name) {
        const keywordMatch = KEYWORD_TO_ICD.find(entry =>
            entry.keywords.some(kw => name.includes(kw))
        );

        if (keywordMatch) {
            const defaults = SPECIALTY_COSTS[keywordMatch.specialty] || SPECIALTY_COSTS['Default'];
            return {
                found: true,
                source: 'keyword_map',
                icdCode: keywordMatch.icd,
                conditionName: keywordMatch.name,
                specialty: keywordMatch.specialty,
                isSurgical: keywordMatch.surgical,
                los: {
                    min: defaults.los_avg - 2,
                    max: defaults.los_avg + 4,
                    avg: defaults.los_avg,
                    icu: defaults.los_icu,
                },
                costData: defaults,
            };
        }
    }

    // ─── LAYER 3: ICD Prefix → Specialty Default ─────────────────────────────
    if (code && code.length >= 1) {
        const specialty = getSpecialtyFromICD(code);
        const defaults = SPECIALTY_COSTS[specialty] || SPECIALTY_COSTS['Default'];
        const isSurgical = /^(K3[5-9]|K4|K5[0-6]|S[0-9]|T[0-7]|O82|M1[6-7])/.test(code);

        return {
            found: true,
            source: 'specialty_default',
            icdCode: code,
            conditionName: name || `${specialty} Condition`,
            specialty: specialty,
            isSurgical: isSurgical,
            los: {
                min: defaults.los_avg - 2,
                max: defaults.los_avg + 4,
                avg: defaults.los_avg,
                icu: defaults.los_icu,
            },
            costData: defaults,
        };
    }

    // ─── LAYER 4: Guaranteed Floor ───────────────────────────────────────────
    const defaults = SPECIALTY_COSTS['Default'];
    return {
        found: true, // ALWAYS return found=true with floor values
        source: 'floor',
        icdCode: 'R69', // Illness, unspecified
        conditionName: name || 'General Medical Admission',
        specialty: 'Default',
        isSurgical: false,
        los: {
            min: MINIMUM_FLOOR.los,
            max: MINIMUM_FLOOR.los + 4,
            avg: MINIMUM_FLOOR.los + 2,
            icu: 0,
        },
        costData: defaults,
    };
}

// ═══════════════════════════════════════════════════════════════════════════
// INFER ICD FROM DIAGNOSIS NAME (When Gemini returns empty)
// ═══════════════════════════════════════════════════════════════════════════

export function inferICDFromDiagnosis(diagnosisName: string): string {
    const name = (diagnosisName || '').toLowerCase();

    // Search keyword mapping
    const match = KEYWORD_TO_ICD.find(entry =>
        entry.keywords.some(kw => name.includes(kw))
    );

    if (match) return match.icd;

    // Fallback: R69 = Illness, unspecified
    return 'R69';
}

// ═══════════════════════════════════════════════════════════════════════════
// MAIN COST CALCULATOR (Guaranteed Valid Output)
// ═══════════════════════════════════════════════════════════════════════════

export function calculateGuaranteedCost(
    icdCode: string,
    diagnosisName: string,
    roomCategory: string,
    isPMJAY: boolean,
    customLOS?: number,
    customICUDays?: number
): GuaranteedCostEstimate {
    // Step 1: Lookup with 4-layer failsafe
    const lookup = lookupICD(icdCode, diagnosisName);
    const costs = lookup.costData;

    // Step 2: Determine LOS (with floor)
    const totalDays = safePositive(customLOS ?? lookup.los.avg, MINIMUM_FLOOR.los);
    const icuDays = safeNumber(customICUDays ?? lookup.los.icu, 0);
    const wardDays = Math.max(1, totalDays - icuDays); // At least 1 ward day

    // Step 3: Calculate room rates based on category
    const roomRates: Record<string, number> = {
        'General Ward': costs.ward,
        'Semi-Private': costs.semi,
        'Private': costs.pvt,
        'Deluxe': costs.pvt * 1.5,
        'ICU': costs.icu,
        'ICCU': costs.icu,
        'NICU': costs.icu,
        'HDU': costs.icu * 0.7,
    };
    const dailyRate = safePositive(roomRates[roomCategory] || costs.ward, MINIMUM_FLOOR.room_rent);

    // Step 4: PMJAY Path
    if (isPMJAY && costs.pmjay_eligible && costs.pmjay_rate > 0) {
        const pkgRate = safePositive(costs.pmjay_rate, 15000);
        const breakdown = lookup.isSurgical ? {
            room_rent: Math.round(pkgRate * 0.15),
            nursing_charges: Math.round(pkgRate * 0.05),
            icu_charges: 0,
            ot_charges: Math.round(pkgRate * 0.20),
            surgeon_fee: Math.round(pkgRate * 0.25),
            anesthetist_fee: Math.round(pkgRate * 0.10),
            consultant_fee: 0,
            investigations: Math.round(pkgRate * 0.10),
            medicines: Math.round(pkgRate * 0.10),
            consumables: Math.round(pkgRate * 0.05),
            implants: 0,
            miscellaneous: 0,
        } : {
            room_rent: Math.round(pkgRate * 0.25),
            nursing_charges: Math.round(pkgRate * 0.10),
            icu_charges: 0,
            ot_charges: 0,
            surgeon_fee: 0,
            anesthetist_fee: 0,
            consultant_fee: Math.round(pkgRate * 0.15),
            investigations: Math.round(pkgRate * 0.20),
            medicines: Math.round(pkgRate * 0.25),
            consumables: 0,
            implants: 0,
            miscellaneous: Math.round(pkgRate * 0.05),
        };

        return {
            source: 'PMJAY',
            conditionName: lookup.conditionName,
            icdCode: lookup.icdCode,
            specialty: lookup.specialty,
            los: { total_days: totalDays, ward_days: wardDays, icu_days: icuDays },
            breakdown,
            total_estimated: pkgRate,
            claimed_amount: pkgRate,
            calculation_confidence: lookup.source === 'cost_db' ? 'high' : lookup.source === 'clinical_db' ? 'medium' : 'low',
        };
    }

    // Step 5: Private Path with guaranteed minimums
    const room_rent = safePositive(dailyRate * wardDays, MINIMUM_FLOOR.room_rent * wardDays);
    const nursing_charges = Math.round(room_rent * 0.15);
    const icu_charges = safePositive(costs.icu * icuDays, 0);
    const consultant_fee = safePositive(costs.consult * totalDays, MINIMUM_FLOOR.consult * totalDays);
    const investigations = safePositive(costs.invest, MINIMUM_FLOOR.investigations);
    const medicines = safePositive(costs.med_per_day * totalDays, MINIMUM_FLOOR.medicines * totalDays);

    // Surgical charges (only if surgical)
    let ot_charges = 0, surgeon_fee = 0, anesthetist_fee = 0;
    if (lookup.isSurgical && costs.procedure > 0) {
        ot_charges = Math.round(costs.procedure * 0.3);
        surgeon_fee = Math.round(costs.procedure * 0.5);
        anesthetist_fee = Math.round(costs.procedure * 0.2);
    }

    // Calculate subtotal and misc
    const subtotal = room_rent + nursing_charges + icu_charges + ot_charges +
        surgeon_fee + anesthetist_fee + consultant_fee + investigations + medicines;
    const miscellaneous = Math.round(subtotal * 0.05);

    // Apply minimum floor
    let total = Math.round((subtotal + miscellaneous) * 1.05);
    if (total < MINIMUM_FLOOR.total_cost) {
        total = MINIMUM_FLOOR.total_cost;
    }

    return {
        source: 'Private',
        conditionName: lookup.conditionName,
        icdCode: lookup.icdCode,
        specialty: lookup.specialty,
        los: { total_days: totalDays, ward_days: wardDays, icu_days: icuDays },
        breakdown: {
            room_rent,
            nursing_charges,
            icu_charges,
            ot_charges,
            surgeon_fee,
            anesthetist_fee,
            consultant_fee,
            investigations,
            medicines,
            consumables: 0,
            implants: 0,
            miscellaneous,
        },
        total_estimated: total,
        claimed_amount: total,
        calculation_confidence: lookup.source === 'cost_db' ? 'high' : lookup.source === 'clinical_db' ? 'medium' : 'low',
    };
}

// ═══════════════════════════════════════════════════════════════════════════
// VALIDATION HELPER: Ensure cost object is valid (call before using)
// ═══════════════════════════════════════════════════════════════════════════

export function validateAndFixCostEstimate(estimate: GuaranteedCostEstimate): GuaranteedCostEstimate {
    // Ensure no NaN or undefined values
    const b = estimate.breakdown;
    const fixedBreakdown = {
        room_rent: safePositive(b.room_rent, MINIMUM_FLOOR.room_rent * estimate.los.ward_days),
        nursing_charges: safePositive(b.nursing_charges, 0),
        icu_charges: safePositive(b.icu_charges, 0),
        ot_charges: safePositive(b.ot_charges, 0),
        surgeon_fee: safePositive(b.surgeon_fee, 0),
        anesthetist_fee: safePositive(b.anesthetist_fee, 0),
        consultant_fee: safePositive(b.consultant_fee, MINIMUM_FLOOR.consult * estimate.los.total_days),
        investigations: safePositive(b.investigations, MINIMUM_FLOOR.investigations),
        medicines: safePositive(b.medicines, MINIMUM_FLOOR.medicines * estimate.los.total_days),
        consumables: safePositive(b.consumables, 0),
        implants: safePositive(b.implants, 0),
        miscellaneous: safePositive(b.miscellaneous, 0),
    };

    const fixedTotal = Object.values(fixedBreakdown).reduce((sum, val) => sum + val, 0);

    return {
        ...estimate,
        breakdown: fixedBreakdown,
        total_estimated: Math.max(fixedTotal, MINIMUM_FLOOR.total_cost),
        claimed_amount: Math.max(fixedTotal, MINIMUM_FLOOR.total_cost),
    };
}
