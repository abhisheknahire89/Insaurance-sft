// ICD PREFIX → SPECIALTY MAPPING (Fallback when keyword mapping fails)
// ═══════════════════════════════════════════════════════════════════════════

function getSpecialtyFromICD(icdCode: string): string {
    if (!icdCode) return 'Default';
    const letter = icdCode.charAt(0).toUpperCase();
    const prefix3 = icdCode.substring(0, 3).toUpperCase();

    // Specific 3-character mappings
    const prefix3Map: Record<string, string> = {
        'J09': 'Pulmonology', 'J10': 'Pulmonology', 'J11': 'Pulmonology', 'J12': 'Pulmonology',
        'J13': 'Pulmonology', 'J14': 'Pulmonology', 'J15': 'Pulmonology', 'J18': 'Pulmonology',
        'J44': 'Pulmonology', 'J45': 'Pulmonology', 'J96': 'Pulmonology',
        'I20': 'Cardiology', 'I21': 'Cardiology', 'I22': 'Cardiology', 'I25': 'Cardiology',
        'I48': 'Cardiology', 'I50': 'Cardiology', 'I10': 'Cardiology',
        'I60': 'Neurology', 'I61': 'Neurology', 'I62': 'Neurology', 'I63': 'Neurology',
        'G40': 'Neurology', 'G41': 'Neurology', 'G03': 'Neurology', 'G04': 'Neurology',
        'K35': 'General Surgery', 'K40': 'General Surgery', 'K56': 'General Surgery',
        'K80': 'General Surgery', 'K85': 'Gastroenterology', 'K92': 'Gastroenterology',
        'N17': 'Nephrology', 'N18': 'Nephrology', 'N39': 'Nephrology', 'N20': 'Urology',
        'E10': 'Endocrine', 'E11': 'Endocrine', 'E05': 'Endocrine',
        'O80': 'Obstetrics', 'O82': 'Obstetrics', 'O14': 'Obstetrics', 'O00': 'Obstetrics',
        'P59': 'Pediatrics', 'P36': 'Pediatrics', 'P07': 'Pediatrics', 'P22': 'Pediatrics',
        'S72': 'Orthopedics', 'S82': 'Orthopedics', 'S52': 'Orthopedics', 'M16': 'Orthopedics',
        'F32': 'Psychiatry', 'F31': 'Psychiatry', 'F20': 'Psychiatry', 'F10': 'Psychiatry',
        'C50': 'Oncology', 'C18': 'Oncology', 'C34': 'Oncology', 'C61': 'Oncology',
        'A41': 'Infectious', 'A01': 'Infectious', 'A90': 'Infectious', 'B50': 'Infectious',
    };
    if (prefix3Map[prefix3]) return prefix3Map[prefix3];

    // Letter-based fallback
    const letterMap: Record<string, string> = {
        'A': 'Infectious', 'B': 'Infectious',
        'C': 'Oncology', 'D': 'Oncology',
        'E': 'Endocrine',
        'F': 'Psychiatry',
