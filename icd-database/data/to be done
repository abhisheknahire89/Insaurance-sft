**Medical Necessity Generator Logic:**

```typescript
function generateMedicalNecessity(input: PreAuthInput, icdData: ICDCondition): string {
  // 1. Get condition from ICD database
  const condition = findConditionByDiagnosis(input.diagnosis);
  
  // 2. Map NEXUS severity to insurance language
  const severityLevel = mapSeverity(input.severity_indicators.pheno_intensity);
  
  // 3. Extract objective findings
  const objectiveFindings = input.evidence_anchors
    .filter(e => e.strength > 0.7)
    .map(e => e.finding);
  
  // 4. Generate statement using template
  return `
    Patient presents with ${input.diagnosis} (ICD-10: ${condition.icd_codes.primary.code}) 
    with probability ${(input.probability * 100).toFixed(0)}% based on clinical assessment.
    
    **Clinical Evidence:**
    ${objectiveFindings.map(f => `• ${f}`).join('\n')}
    
    **Hospitalization Justification:**
    OPD management is contraindicated due to:
    ${condition.admission_criteria.filter(c => matchesCriteria(c, input)).map(c => `• ${c}`).join('\n')}
    
    **Severity Assessment:**
    - Clinical Severity Score: ${severityLevel}/10
    - Urgency Index: ${(input.severity_indicators.urgency_quotient * 10).toFixed(1)}/10
    - Deterioration Risk: ${input.severity_indicators.deterioration_velocity > 0.5 ? 'HIGH' : 'MODERATE'}
    
    **Risk if Not Admitted:**
    ${generateRiskStatement(input.diagnosis, input.severity_indicators)}
    
    **Required Monitoring:**
    ${condition.documentation_must_include.join(', ')}
  `;
}
```

